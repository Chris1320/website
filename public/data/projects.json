    {
        "id": 2,
        "name": "BENTO (Baliwag Education Network for Tracking Canteen Operations)",
        "dateStart": "2024-08-06",
        "dateEnd": "2025-09-19",
        "visible": true,
        "status": "stable",
        "shortDescription": "BENTO is a School Canteen Automated Reporting System for the Department of Education (DepEd) Schools Division Office (SDO) of the City of Baliwag in the Philippines. It is designed to streamline and enhance the efficiency of canteen finance reporting and monitoring processes within the schools.",
        "responsibilities": [
            "Led a team of 3 in the development of BENTO, a web-based canteen finance tracking system, streamlining workflows of 30 public schools under the Baliwag Department of Education (DepEd) Schools Division Office (SDO).",
            "Developed a Next.js app (TypeScript/React) using Mantine UI, Tailwind CSS, and Motion.",
            "Engineered a REST API with FastAPI (Python) as the backend, integrating AI insights and chatbot via Google Gemini.",
            "Maintained PostgreSQL and MySQL database management systems for storing site data.",
            "Implemented CI/CD pipelines (via GitHub Actions) to automate testing and deployment, reducing deployment errors.",
            "Enforced Git branching strategies and GitHub code reviews, ensuring stable versions."
        ],
